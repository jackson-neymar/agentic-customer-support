# OpenAI 配置
OPENAI_API_KEY="your_openai_api_key_here"
OPENAI_BASE_URL="https://api.openai.com/v1/"

# LangSmith 追踪（可选）
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY="your_langchain_api_key_here"
LANGCHAIN_PROJECT="your_project_name_here"

# 智谱AI（可选）
ZHIPUAI_API_KEY="your_zhipuai_api_key_here"

# GoHumanLoop（可选，用于 HITL 人工审核）
# GOHUMANLOOP_API_KEY="your_gohumanloop_api_key_here"

# Qdrant 向量数据库（可选，使用远程实例时配置）
# QDRANT_URL="your_qdrant_url_here"

# WooCommerce 电商接口（可选）
WOOCOMMERCE_API_URL="https://your-store.com/wp-json/wc/v3"
WOOCOMMERCE_API_KEY="your_woocommerce_consumer_key_here"
WOOCOMMERCE_API_SECRET="your_woocommerce_consumer_secret_here"

# MCP Services
OPENWEATHERMAP_API_KEY="your_openweathermap_api_key_here"

# GDS 数据源提供商: sqlite | amadeus_mock
GDS_PROVIDER=sqlite
